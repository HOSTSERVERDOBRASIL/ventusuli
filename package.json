{
  "name": "ventu-suli",
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "start:prod": "next start -H 0.0.0.0 -p 3000",
    "railway:start": "sh -c \"./node_modules/.bin/prisma migrate deploy && next start -H 0.0.0.0 -p ${PORT:-3000}\"",
    "test": "node --test tests/integration/**/*.test.mjs",
    "test:integration": "node --test tests/integration/**/*.test.mjs",
    "test:e2e": "node --test tests/integration/**/*.test.mjs",
    "test:smoke": "node --test tests/smoke/**/*.smoke.mjs",
    "lint": "next lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "type-check": "tsc --noEmit --incremental false",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:seed": "prisma db seed",
    "db:init:demo": "npm run db:deploy && npm run db:seed",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:db:migrate": "docker compose exec -T app ./node_modules/.bin/prisma migrate deploy",
    "docker:db:status": "docker compose exec -T app ./node_modules/.bin/prisma migrate status",
    "docker:db:seed": "docker compose exec app npm run db:seed",
    "docker:prod:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose --env-file .env.production -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose --env-file .env.production -f docker-compose.prod.yml logs -f app proxy db",
    "docker:prod:db:status": "docker compose --env-file .env.production -f docker-compose.prod.yml exec -T app ./node_modules/.bin/prisma migrate status",
    "docker:prod:db:migrate": "docker compose --env-file .env.production -f docker-compose.prod.yml exec -T app ./node_modules/.bin/prisma migrate deploy",
    "docker:prod:db:seed": "docker compose --env-file .env.production -f docker-compose.prod.yml exec -T app npm run db:seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Ventu Suli - Plataforma para gestao de assessorias esportivas",
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,md,css}": [
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.13",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-countdown": "^2.3.6",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3",
    "zod": "^3.25.76"
  }
}
