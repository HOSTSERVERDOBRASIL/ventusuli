# =========================
# Required (production)
# =========================
DOMAIN=app.seudominio.com
NEXT_PUBLIC_APP_URL=https://app.seudominio.com
NEXTAUTH_URL=https://app.seudominio.com

# JWT_SECRET >= 32 chars
# NEXTAUTH_SECRET >= 16 chars
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
NEXTAUTH_SECRET=troque-por-um-segredo-longo-e-aleatorio

# DATABASE_URL is required by runtime env validation
POSTGRES_USER=ventusuli
POSTGRES_PASSWORD=troque-uma-senha-forte
POSTGRES_DB=ventu_suli
DATABASE_URL=postgresql://ventusuli:troque-uma-senha-forte@db:5432/ventu_suli?schema=public

# =========================
# Runtime mode
# =========================
NEXT_PUBLIC_DEMO_MODE=false
DEMO_AUTH_ENABLED=false
DEMO_SEED_ENABLED=false
PUBLIC_ADMIN_REGISTRATION_ENABLED=false
NEXT_PUBLIC_PUBLIC_ADMIN_REGISTRATION_ENABLED=false
SUPER_ADMIN_EMAIL=superadmin@seudominio.com
SUPER_ADMIN_PASSWORD=troque-por-senha-super-admin-forte
MFA_REQUIRED_ROLES=SUPER_ADMIN,ADMIN,FINANCE,COACH,ATHLETE
# You can also use MFA_REQUIRED_ROLES=ALL.

# =========================
# Optional integrations
# =========================
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_SANDBOX=false
EFI_CERT_PATH=./certs/efi.p12
PAYMENT_WEBHOOK_SECRET=

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Optional override. Default: ${NEXT_PUBLIC_APP_URL}/api/integrations/strava/callback
STRAVA_REDIRECT_URI=
# Required for GET verification at /api/integrations/strava/webhook
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Notices/Telegram:
# - TELEGRAM_NOTICES_ENABLED habilita envio global default
# - TELEGRAM_CHAT_ID e TELEGRAM_BOT_TOKEN podem ser sobrescritos por organization.settings.integrations.telegram
TELEGRAM_NOTICES_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

RATE_LIMIT_BACKEND=auto
REDIS_URL=
# Production rate limit backend (choose one):
# 1) Railway Redis: REDIS_URL=redis://...
# 2) Upstash Redis REST:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=
STORAGE_DRIVER=local
UPLOAD_MAX_FILE_MB=5
