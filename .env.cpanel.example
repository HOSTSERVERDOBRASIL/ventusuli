# =========================
# cPanel / Node.js App
# =========================
# Ajuste para o domínio/subdomínio configurado no cPanel
NEXT_PUBLIC_APP_URL=https://app.seudominio.com
NEXTAUTH_URL=https://app.seudominio.com

# Banco PostgreSQL externo ou remoto liberado para o host do cPanel
# Exemplo: postgresql://USUARIO:SENHA@HOST:5432/BANCO?schema=public&sslmode=require
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/BANCO?schema=public

# Segredos obrigatórios
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio-com-64-caracteres-ou-mais
NEXTAUTH_SECRET=troque-por-um-segredo-longo-e-aleatorio-com-32-caracteres-ou-mais

# Runtime mode
NODE_ENV=production
NEXT_PUBLIC_DEMO_MODE=false
DEMO_AUTH_ENABLED=false
DEMO_SEED_ENABLED=false
PUBLIC_ADMIN_REGISTRATION_ENABLED=false
NEXT_PUBLIC_PUBLIC_ADMIN_REGISTRATION_ENABLED=false
SUPER_ADMIN_EMAIL=superadmin@seudominio.com
SUPER_ADMIN_PASSWORD=troque-por-senha-super-admin-forte

# Opcionais
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_SANDBOX=false
EFI_CERT_PATH=./certs/efi.p12
PAYMENT_WEBHOOK_SECRET=

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=
STRAVA_WEBHOOK_VERIFY_TOKEN=

TELEGRAM_NOTICES_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# cPanel geralmente nao tem Redis; use memory apenas se a app roda em uma unica instancia.
RATE_LIMIT_BACKEND=memory
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=
STORAGE_DRIVER=local
UPLOAD_MAX_FILE_MB=5
