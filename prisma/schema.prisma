// Ventu Suli - Prisma Schema
// Fase 1: Auth + Multi-tenant + Events

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  FINANCE
  COACH
  ATHLETE
  ORGANIZER
  MANAGER
  PREMIUM_ATHLETE
  SUPPORT
  MODERATOR
  PARTNER

  @@schema("public")
}

enum AccountStatus {
  ACTIVE
  PENDING_INVITE
  PENDING_APPROVAL
  SUSPENDED

  @@schema("public")
}

enum MfaMethod {
  TOTP
  EMAIL_OTP
  RECOVERY_CODE

  @@schema("public")
}

enum AuthChallengePurpose {
  LOGIN_MFA
  MFA_SETUP

  @@schema("public")
}

enum AthleteStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  BLOCKED

  @@schema("public")
}

enum AthleteSignupSource {
  SLUG
  INVITE
  ADMIN

  @@schema("public")
}

enum OrgPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE

  @@schema("public")
}

enum OrgStatus {
  PENDING_SETUP
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED

  @@schema("public")
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  FINISHED

  @@schema("public")
}

enum RegistrationStatus {
  INTERESTED
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED

  @@schema("public")
}

enum AttendanceStatus {
  PENDING
  PRESENT
  ABSENT

  @@schema("public")
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  REFUNDED
  CANCELLED

  @@schema("public")
}

enum CollectiveStatus {
  OPEN
  CLOSED
  CANCELLED

  @@schema("public")
}

enum CommunityReactionType {
  LIKE
  FIRE
  APPLAUSE

  @@schema("public")
}

enum NoticeAudience {
  ALL
  ATHLETES
  COACHES
  ADMINS

  @@schema("public")
}

enum NoticeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@schema("public")
}

enum NoticeChannel {
  IN_APP
  TELEGRAM

  @@schema("public")
}

enum NoticeDeliveryStatus {
  PENDING
  SENT
  FAILED

  @@schema("public")
}

enum LedgerType {
  CREDIT
  DEBIT
  EXPIRATION
  ADJUSTMENT
  REFUND

  @@schema("public")
}

enum LedgerSource {
  EVENT_PARTICIPATION
  EARLY_SIGNUP
  EARLY_PAYMENT
  CAMPAIGN_BONUS
  ACTIVITY_APPROVAL
  REFERRAL
  RECURRENCE
  BIRTHDAY
  MANUAL
  REDEMPTION
  EXPIRATION

  @@schema("public")
}

enum RedemptionStatus {
  REQUESTED
  PENDING_PAYMENT
  APPROVED
  SEPARATED
  DELIVERED
  CANCELLED
  PAYMENT_FAILED

  @@schema("public")
}

enum StravaSyncTrigger {
  WEBHOOK
  MANUAL
  OAUTH_CALLBACK
  SCHEDULED

  @@schema("public")
}

enum StravaSyncStatus {
  RECEIVED
  PROCESSING
  SYNCED
  SKIPPED
  IGNORED
  FAILED

  @@schema("public")
}

enum RankingSnapshotMetric {
  DISTANCE_M
  MOVING_TIME_S
  ACTIVITY_COUNT

  @@schema("public")
}

enum LoyaltyLevelKey {
  STARTER
  MEMBER
  PLUS
  PRIME
  BLACK

  @@schema("public")
}

enum LoyaltyMissionType {
  ONBOARDING
  FREQUENCY
  SPEND
  ENGAGEMENT
  SEASONAL
  DYNAMIC

  @@schema("public")
}

enum LoyaltyMissionStatus {
  ACTIVE
  PAUSED
  ARCHIVED

  @@schema("public")
}

enum UserMissionStatus {
  IN_PROGRESS
  COMPLETED
  CLAIMED
  EXPIRED

  @@schema("public")
}

enum LoyaltyBadgeCategory {
  FIRST_ACTION
  RECURRENT
  ELITE
  REFERRAL
  SPECIAL

  @@schema("public")
}

enum PointActivityEntryStatus {
  PENDING
  APPROVED
  REJECTED

  @@schema("public")
}

enum PointActivityEntrySource {
  ADMIN
  USER

  @@schema("public")
}

enum SportLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ELITE

  @@schema("public")
}

enum TrainingPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED

  @@schema("public")
}

enum WorkoutSessionStatus {
  PENDING
  COMPLETED
  PARTIAL
  MISSED

  @@schema("public")
}

enum AIRecommendationStatus {
  PENDING
  APPLIED
  DISMISSED

  @@schema("public")
}

enum AuditActorType {
  USER
  SYSTEM
  INTEGRATION

  @@schema("public")
}

enum InternalEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  SKIPPED

  @@schema("public")
}

enum PhotoGalleryStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@schema("public")
}

enum PhotoAssetStatus {
  PROCESSING
  PUBLISHED
  HIDDEN
  ARCHIVED

  @@schema("public")
}

enum PhotoMatchType {
  MANUAL
  BIB_NUMBER
  FACIAL_RECOGNITION
  IMPORT

  @@schema("public")
}

enum PhotoMatchStatus {
  PENDING
  CONFIRMED
  REJECTED

  @@schema("public")
}

enum PhotoPurchaseStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED

  @@schema("public")
}

enum PhotoUnlockType {
  PURCHASE
  POINTS
  ADMIN_GRANT
  PACKAGE

  @@schema("public")
}

enum SponsorStatus {
  ACTIVE
  INACTIVE
  ARCHIVED

  @@schema("public")
}

enum SponsorCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  FINISHED
  CANCELLED

  @@schema("public")
}

model Organization {
  id                 String    @id @default(uuid())
  name               String
  slug               String    @unique
  logo_url           String?
  plan               OrgPlan   @default(FREE)
  status             OrgStatus @default(PENDING_SETUP)
  setup_completed_at DateTime?
  plan_expires_at    DateTime?
  settings           Json?
  created_at         DateTime  @default(now())

  users                     User[]
  refresh_tokens            RefreshToken[]
  athlete_profiles          AthleteProfile[]
  events                    Event[]
  registrations             Registration[]
  payments                  Payment[]
  financial_entries         FinancialEntry[]
  collective_signups        CollectiveSignup[]
  invites                   OrganizationInvite[]
  admin_invites             AdminActivationInvite[]
  community_posts           CommunityPost[]
  community_comments        CommunityComment[]
  community_reactions       CommunityReaction[]
  notices                   Notice[]
  notice_deliveries         NoticeDelivery[]
  notification_preferences  NotificationPreference[]
  notification_templates    NotificationTemplate[]
  notification_jobs         NotificationJob[]
  notification_logs         NotificationLog[]
  event_point_rules         EventPointRule[]
  athlete_point_ledger      AthletePointLedger[]
  reward_items              RewardItem[]
  reward_redemptions        RewardRedemption[]
  loyalty_profiles          UserLoyalty[]
  loyalty_missions          LoyaltyMission[]
  loyalty_badges            LoyaltyBadge[]
  loyalty_user_missions     UserLoyaltyMission[]
  loyalty_user_badges       UserLoyaltyBadge[]
  loyalty_program_events    LoyaltyProgramEvent[]
  point_activities          PointActivity[]
  point_activity_entries    PointActivityEntry[]
  platform_billing_invoices PlatformBillingInvoice[]
  strava_connections        StravaConnection[]
  activities                Activity[]
  strava_sync_logs          StravaSyncLog[]
  ranking_snapshots         RankingSnapshot[]
  auth_challenges           AuthChallenge[]
  mfa_settings              UserMfaSettings[]
  exercises                 Exercise[]
  training_plans            TrainingPlan[]
  training_sessions         WorkoutSession[]
  training_feedbacks        AthleteFeedback[]
  ai_recommendations        AIRecommendation[]
  audit_logs                AuditLog[]
  internal_events           InternalEvent[]
  photo_galleries           PhotoGallery[]
  photos                    Photo[]
  photo_athlete_matches     PhotoAthleteMatch[]
  photo_purchases           PhotoPurchase[]
  photo_unlocks             PhotoUnlock[]
  sponsors                  Sponsor[]
  sponsor_contacts          SponsorContact[]
  sponsor_campaigns         SponsorCampaign[]
  sponsor_placements        SponsorPlacement[]
  sponsor_metrics           SponsorMetric[]
  user_access_profiles      UserAccessProfile[]

  @@index([slug])
  @@index([status])
  @@map("organizations")
  @@schema("public")
}

model User {
  id              String        @id @default(uuid())
  organization_id String
  organization    Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  email           String        @unique
  password_hash   String
  role            UserRole      @default(ATHLETE)
  account_status  AccountStatus @default(ACTIVE)
  name            String
  avatar_url      String?
  email_verified  Boolean       @default(false)
  last_login_at   DateTime?
  created_at      DateTime      @default(now())

  refresh_tokens             RefreshToken[]
  password_reset_tokens      PasswordResetToken[]
  auth_challenges            AuthChallenge[]
  mfa_settings               UserMfaSettings?
  access_profiles            UserAccessProfile[]
  athlete_profile            AthleteProfile?
  created_events             Event[]                 @relation("EventCreator")
  registrations              Registration[]
  payments                   Payment[]
  financial_entries_created  FinancialEntry[]        @relation("FinancialEntryCreator")
  financial_entries_subject  FinancialEntry[]        @relation("FinancialEntrySubject")
  created_collective_signups CollectiveSignup[]      @relation("CollectiveSignupCreator")
  collective_memberships     CollectiveMember[]
  community_posts            CommunityPost[]
  community_comments         CommunityComment[]
  community_reactions        CommunityReaction[]
  created_notices            Notice[]                @relation("NoticeCreator")
  notification_preference    NotificationPreference?
  notification_jobs          NotificationJob[]       @relation("NotificationJobRecipient")
  notification_logs          NotificationLog[]       @relation("NotificationLogRecipient")
  athlete_point_ledger       AthletePointLedger[]
  reward_redemptions         RewardRedemption[]
  loyalty_profile            UserLoyalty?
  loyalty_missions           UserLoyaltyMission[]
  loyalty_badges             UserLoyaltyBadge[]
  loyalty_program_events     LoyaltyProgramEvent[]
  point_activity_entries     PointActivityEntry[]
  strava_connection          StravaConnection?
  activities                 Activity[]
  strava_sync_logs           StravaSyncLog[]
  generated_rankings         RankingSnapshot[]       @relation("RankingSnapshotGenerator")
  assigned_training_plans    TrainingPlan[]          @relation("TrainingPlanAthlete")
  coached_training_plans     TrainingPlan[]          @relation("TrainingPlanCoach")
  workout_sessions           WorkoutSession[]        @relation("WorkoutSessionAthlete")
  coached_workout_sessions   WorkoutSession[]        @relation("WorkoutSessionCoach")
  athlete_feedbacks          AthleteFeedback[]       @relation("AthleteFeedbackAthlete")
  ai_recommendations         AIRecommendation[]      @relation("AIRecommendationAthlete")
  coach_ai_recommendations   AIRecommendation[]      @relation("AIRecommendationCoach")
  created_exercises          Exercise[]              @relation("ExerciseCreator")
  training_plan_reviews      AIRecommendation[]      @relation("AIRecommendationReviewer")
  audit_logs                 AuditLog[]              @relation("AuditActor")
  internal_events            InternalEvent[]
  photographed_photos        Photo[]                 @relation("PhotoPhotographer")
  photo_athlete_matches      PhotoAthleteMatch[]
  photo_purchases            PhotoPurchase[]
  photo_unlocks              PhotoUnlock[]
  sponsor_contacts_created   SponsorContact[]        @relation("SponsorContactCreator")

  @@index([organization_id])
  @@index([email])
  @@index([role])
  @@map("users")
  @@schema("public")
}

model UserAccessProfile {
  id              String       @id @default(uuid())
  user_id         String
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  role            UserRole
  active          Boolean      @default(true)
  assigned_by     String?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  @@unique([user_id, role])
  @@index([organization_id, role, active])
  @@index([user_id, active])
  @@map("user_access_profiles")
  @@schema("public")
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  user_id    String
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  @@index([user_id, created_at(sort: Desc)])
  @@index([expires_at])
  @@map("password_reset_tokens")
  @@schema("public")
}

model UserMfaSettings {
  id                     String       @id @default(uuid())
  user_id                String       @unique
  user                   User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization_id        String
  organization           Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  enabled                Boolean      @default(false)
  totp_secret            String?
  email_otp_enabled      Boolean      @default(true)
  recovery_codes_hashes  String[]     @default([])
  recovery_codes_version Int          @default(1)
  last_verified_at       DateTime?
  created_at             DateTime     @default(now())
  updated_at             DateTime     @updatedAt

  @@index([organization_id, enabled])
  @@map("user_mfa_settings")
  @@schema("public")
}

model AuthChallenge {
  id                  String               @id @default(uuid())
  user_id             String
  user                User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization_id     String
  organization        Organization         @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  purpose             AuthChallengePurpose
  token_hash          String               @unique
  primary_method      MfaMethod            @default(TOTP)
  available_methods   MfaMethod[]          @default([TOTP])
  email_otp_code_hash String?
  temp_totp_secret    String?
  remember_me         Boolean              @default(false)
  failed_attempts     Int                  @default(0)
  max_attempts        Int                  @default(5)
  expires_at          DateTime
  email_otp_sent_at   DateTime?
  verified_at         DateTime?
  consumed_at         DateTime?
  metadata            Json?
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt

  @@index([user_id, purpose, expires_at(sort: Desc)])
  @@index([organization_id, purpose, created_at(sort: Desc)])
  @@index([expires_at])
  @@map("auth_challenges")
  @@schema("public")
}

model RefreshToken {
  id              String       @id @default(uuid())
  user_id         String
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  token_hash      String       @unique
  expires_at      DateTime
  remember_me     Boolean      @default(true)
  revoked         Boolean      @default(false)
  created_at      DateTime     @default(now())

  @@index([user_id])
  @@index([organization_id])
  @@index([token_hash])
  @@index([expires_at])
  @@map("refresh_tokens")
  @@schema("public")
}

model AthleteProfile {
  id                      String              @id @default(uuid())
  user_id                 String              @unique
  user                    User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization_id         String
  organization            Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  athlete_status          AthleteStatus       @default(ACTIVE)
  signup_source           AthleteSignupSource @default(SLUG)
  onboarding_completed_at DateTime?
  cpf                     String?
  birth_date              DateTime?
  gender                  String?
  phone                   String?
  city                    String?
  state                   String?
  weight_kg               Decimal?            @db.Decimal(5, 2)
  height_cm               Int?
  shirt_size              String?
  emergency_contact       Json?
  member_sequence         Int?
  member_number           String?
  member_since            DateTime?
  primary_modality        String?
  sport_level             SportLevel?
  sport_goal              String?
  injury_history          String?
  weekly_availability     Json?
  available_equipment     String[]            @default([])
  resting_heart_rate      Int?
  threshold_pace          String?
  max_load_notes          String?
  next_competition_date   DateTime?
  medical_restrictions    String?
  coach_notes             String?
  created_at              DateTime            @default(now())

  training_plans   TrainingPlan[]
  workout_sessions WorkoutSession[]

  @@unique([organization_id, member_sequence])
  @@unique([organization_id, member_number])
  @@index([organization_id])
  @@index([organization_id, athlete_status])
  @@index([organization_id, signup_source])
  @@index([user_id])
  @@index([cpf])
  @@index([member_number])
  @@map("athlete_profiles")
  @@schema("public")
}

model StravaConnection {
  id                String       @id @default(uuid())
  user_id           String       @unique
  user              User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization_id   String
  organization      Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  strava_athlete_id String
  access_token      String
  refresh_token     String
  expires_at        DateTime
  scopes            String[]
  last_sync_at      DateTime?
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  @@unique([organization_id, strava_athlete_id])
  @@index([organization_id, updated_at(sort: Desc)])
  @@index([organization_id, expires_at(sort: Asc)])
  @@index([user_id])
  @@map("strava_connections")
  @@schema("public")
}

model Activity {
  id                  String       @id @default(uuid())
  external_source     String
  external_id         String
  user_id             String
  user                User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization_id     String
  organization        Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  type                String
  name                String
  distance_m          Int?
  moving_time_s       Int?
  elapsed_time_s      Int?
  average_pace_sec_km Decimal?     @db.Decimal(8, 2)
  average_hr          Int?
  max_hr              Int?
  elevation_gain_m    Int?
  activity_date       DateTime
  raw_payload         Json?
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  @@unique([external_source, external_id])
  @@index([organization_id, user_id, activity_date(sort: Desc)])
  @@index([user_id, activity_date(sort: Desc)])
  @@index([organization_id, activity_date(sort: Desc)])
  @@index([organization_id, type, activity_date(sort: Desc)])
  @@index([organization_id, activity_date, user_id])
  @@index([organization_id, user_id, type, activity_date(sort: Desc)])
  @@map("activities")
  @@schema("public")
}

model StravaSyncLog {
  id                String            @id @default(uuid())
  organization_id   String?
  organization      Organization?     @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  user_id           String?
  user              User?             @relation(fields: [user_id], references: [id], onDelete: SetNull)
  strava_athlete_id String
  trigger           StravaSyncTrigger @default(WEBHOOK)
  status            StravaSyncStatus  @default(RECEIVED)
  idempotency_key   String            @unique
  object_type       String
  aspect_type       String
  object_id         String
  subscription_id   String?
  event_time        DateTime?
  payload           Json?
  sync_result       Json?
  error_message     String?
  created_at        DateTime          @default(now())
  processed_at      DateTime?
  updated_at        DateTime          @updatedAt

  @@index([status, created_at(sort: Desc)])
  @@index([organization_id, created_at(sort: Desc)])
  @@index([organization_id, status, created_at(sort: Desc)])
  @@index([strava_athlete_id, created_at(sort: Desc)])
  @@map("strava_sync_logs")
  @@schema("public")
}

model RankingSnapshot {
  id              String                @id @default(uuid())
  organization_id String
  organization    Organization          @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  metric          RankingSnapshotMetric
  period_start    DateTime
  period_end      DateTime
  generated_at    DateTime              @default(now())
  generated_by    String?
  generator       User?                 @relation("RankingSnapshotGenerator", fields: [generated_by], references: [id], onDelete: SetNull)
  payload         Json

  @@index([organization_id, metric, period_end(sort: Desc)])
  @@index([organization_id, generated_at(sort: Desc)])
  @@index([generated_by])
  @@map("ranking_snapshots")
  @@schema("public")
}

model Event {
  id                    String       @id @default(uuid())
  organization_id       String
  organization          Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_by            String
  creator               User         @relation("EventCreator", fields: [created_by], references: [id], onDelete: Cascade)
  name                  String
  city                  String?
  state                 String?      @db.Char(2)
  address               String?
  latitude              Decimal?     @db.Decimal(9, 6)
  longitude             Decimal?     @db.Decimal(9, 6)
  check_in_radius_m     Int          @default(100)
  proximity_radius_m    Int          @default(200)
  event_date            DateTime
  registration_deadline DateTime?
  description           String?
  image_url             String?
  external_url          String?
  status                EventStatus  @default(DRAFT)
  created_at            DateTime     @default(now())

  distances               EventDistance[]
  registrations           Registration[]
  collective_signups      CollectiveSignup[]
  photo_galleries         PhotoGallery[]
  photos                  Photo[]
  sponsor_campaign_events SponsorCampaignEvent[]

  @@index([organization_id])
  @@index([event_date])
  @@index([status])
  @@map("events")
  @@schema("public")
}

model EventDistance {
  id               String  @id @default(uuid())
  event_id         String
  event            Event   @relation(fields: [event_id], references: [id], onDelete: Cascade)
  label            String
  distance_km      Decimal @db.Decimal(6, 3)
  price_cents      Int
  max_slots        Int?
  registered_count Int     @default(0)

  registrations      Registration[]
  collective_members CollectiveMember[]

  @@index([event_id])
  @@map("event_distances")
  @@schema("public")
}

model Registration {
  id                    String             @id @default(uuid())
  user_id               String
  user                  User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event_id              String
  event                 Event              @relation(fields: [event_id], references: [id], onDelete: Cascade)
  distance_id           String
  distance              EventDistance      @relation(fields: [distance_id], references: [id], onDelete: Cascade)
  organization_id       String
  organization          Organization       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  status                RegistrationStatus @default(INTERESTED)
  attendance_status     AttendanceStatus   @default(PENDING)
  attendance_checked_at DateTime?
  attendance_checked_by String?
  check_in_at           DateTime?
  check_in_latitude     Decimal?           @db.Decimal(9, 6)
  check_in_longitude    Decimal?           @db.Decimal(9, 6)
  check_in_distance_m   Int?
  check_out_at          DateTime?
  check_out_latitude    Decimal?           @db.Decimal(9, 6)
  check_out_longitude   Decimal?           @db.Decimal(9, 6)
  check_out_distance_m  Int?
  notes                 String?
  registered_at         DateTime           @default(now())

  payment Payment?

  @@unique([user_id, event_id, distance_id])
  @@index([organization_id])
  @@index([user_id])
  @@index([organization_id, event_id, attendance_status])
  @@index([organization_id, event_id, check_in_at])
  @@map("registrations")
  @@schema("public")
}

model Payment {
  id              String        @id @default(uuid())
  registration_id String        @unique
  registration    Registration  @relation(fields: [registration_id], references: [id], onDelete: Cascade)
  user_id         String
  user            User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization_id String
  organization    Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  efi_charge_id   String?       @unique
  efi_tx_id       String?       @unique
  amount_cents    Int
  fee_cents       Int           @default(0)
  net_cents       Int
  status          PaymentStatus @default(PENDING)
