  id             String                   @id @default(cuid())
  organizationId String
  activityId     String
  userId         String
  points         Int
  status         PointActivityEntryStatus @default(PENDING)
  source         PointActivityEntrySource @default(ADMIN)
  note           String?
  proofUrl       String?
  referenceCode  String                   @unique
  ledgerEntryId  String?
  createdBy      String
  approvedBy     String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  approvedAt     DateTime?
  rejectedAt     DateTime?
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activity       PointActivity            @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([organizationId, userId, createdAt(sort: Desc)])
  @@map("point_activity_entries")
  @@schema("public")
}

model UserLoyalty {
  id                    String          @id @default(cuid())
  userId                String          @unique
  organizationId        String
  currentLevelKey       LoyaltyLevelKey @default(STARTER)
  availablePoints       Int             @default(0)
  lifetimePoints        Int             @default(0)
  lastActivityAt        DateTime?
  inactivityDowngradeAt DateTime?
  streakCurrent         Int             @default(0)
  streakBest            Int             @default(0)
  lastStreakAt          DateTime?
  segment               String          @default("novo")
  metadata              Json?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, currentLevelKey])
  @@index([organizationId, segment])
  @@map("users_loyalty")
  @@schema("public")
}

model LoyaltyLevel {
  id                String          @id @default(cuid())
  key               LoyaltyLevelKey @unique
  name              String
  minLifetimePoints Int
  multiplier        Decimal         @db.Decimal(5, 2)
  benefits          Json?
  active            Boolean         @default(true)
  sortOrder         Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([active, sortOrder])
  @@map("loyalty_levels")
  @@schema("public")
}

model LoyaltyMission {
  id               String               @id @default(cuid())
  organizationId   String
  code             String
  name             String
  description      String?
  type             LoyaltyMissionType
  targetValue      Int                  @default(1)
  rewardPoints     Int                  @default(0)
  rewardBadgeId    String?
  startAt          DateTime?
  endAt            DateTime?
  repeatable       Boolean              @default(false)
  status           LoyaltyMissionStatus @default(ACTIVE)
  levelRequirement LoyaltyLevelKey?
  metadata         Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rewardBadge      LoyaltyBadge?        @relation("MissionRewardBadge", fields: [rewardBadgeId], references: [id], onDelete: SetNull)
  userMissions     UserLoyaltyMission[]

  @@unique([organizationId, code])
  @@index([organizationId, status, type])
  @@index([organizationId, startAt, endAt])
  @@map("missions")
  @@schema("public")
}

model UserLoyaltyMission {
  id             String            @id @default(cuid())
  missionId      String
  userId         String
  organizationId String
  cycleKey       String            @default("default")
  progressValue  Int               @default(0)
  status         UserMissionStatus @default(IN_PROGRESS)
  completedAt    DateTime?
  claimedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  mission        LoyaltyMission    @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([missionId, userId, cycleKey])
  @@index([organizationId, status, updatedAt(sort: Desc)])
  @@index([userId, status, updatedAt(sort: Desc)])
  @@map("user_missions")
  @@schema("public")
}

model LoyaltyBadge {
  id             String               @id @default(cuid())
  organizationId String
  code           String
  name           String
  description    String?
  icon           String?
  category       LoyaltyBadgeCategory @default(SPECIAL)
  active         Boolean              @default(true)
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userBadges     UserLoyaltyBadge[]
  rewardMissions LoyaltyMission[]     @relation("MissionRewardBadge")

  @@unique([organizationId, code])
  @@index([organizationId, category, active])
  @@map("badges")
  @@schema("public")
}

model UserLoyaltyBadge {
  id             String       @id @default(cuid())
  badgeId        String
  userId         String
  organizationId String
  sourceEventId  String?
  awardedAt      DateTime     @default(now())
  createdAt      DateTime     @default(now())
  badge          LoyaltyBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([badgeId, userId])
  @@index([organizationId, awardedAt(sort: Desc)])
  @@index([userId, awardedAt(sort: Desc)])
  @@map("user_badges")
  @@schema("public")
}

model LoyaltyProgramEvent {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  eventName      String
  sourceEventId  String
  idempotencyKey String?
  payload        Json?
  processedAt    DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([organizationId, sourceEventId])
  @@index([organizationId, eventName, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("loyalty_program_events")
  @@schema("public")
}

model AuditLog {
  id             String         @id @default(cuid())
  organizationId String?
  actorId        String?
  actorType      AuditActorType @default(USER)
  action         String
  entityType     String
  entityId       String?
  requestId      String?
  ipAddress      String?
  userAgent      String?
  beforeData     Json?
  afterData      Json?
  metadata       Json?
  createdAt      DateTime       @default(now())
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor          User?          @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
  @@schema("public")
}

model InternalEvent {
  id             String              @id @default(cuid())
  organizationId String
  userId         String?
  name           String
  sourceType     String
  sourceId       String
  idempotencyKey String
  payload        Json?
  status         InternalEventStatus @default(PENDING)
  attempts       Int                 @default(0)
  lastError      String?
  processedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, name, createdAt(sort: Desc)])
  @@index([organizationId, status, createdAt(sort: Asc)])
  @@map("internal_events")
  @@schema("public")
}

model PhotoGallery {
  id             String             @id @default(cuid())
  organizationId String
  eventId        String?
  title          String
  description    String?
  coverPhotoId   String?
  status         PhotoGalleryStatus @default(DRAFT)
  publishedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event?             @relation(fields: [eventId], references: [id], onDelete: SetNull)
  photos         Photo[]

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([organizationId, eventId])
  @@map("photo_galleries")
  @@schema("public")
}

model Photo {
  id                  String              @id @default(cuid())
  organizationId      String
  galleryId           String
  eventId             String?
  photographerId      String?
  originalStorageKey  String
  previewStorageKey   String?
  thumbnailStorageKey String?
  watermarkStorageKey String?
  originalUrl         String?
  previewUrl          String?
  thumbnailUrl        String?
  watermarkUrl        String?
  priceCents          Int                 @default(0)
  pointsCost          Int                 @default(0)
  status              PhotoAssetStatus    @default(PROCESSING)
  metadata            Json?
  takenAt             DateTime?
  uploadedAt          DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gallery             PhotoGallery        @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  event               Event?              @relation(fields: [eventId], references: [id], onDelete: SetNull)
  photographer        User?               @relation("PhotoPhotographer", fields: [photographerId], references: [id], onDelete: SetNull)
  athleteMatches      PhotoAthleteMatch[]
  purchaseItems       PhotoPurchaseItem[]
  unlocks             PhotoUnlock[]

  @@index([organizationId, galleryId, status])
  @@index([organizationId, eventId, status])
  @@index([organizationId, uploadedAt(sort: Desc)])
  @@map("photos")
  @@schema("public")
}

model PhotoAthleteMatch {
  id              String           @id @default(cuid())
  organizationId  String
  photoId         String
  athleteId       String
  bibNumber       String?
  matchType       PhotoMatchType
  confidenceScore Decimal?         @db.Decimal(5, 4)
  status          PhotoMatchStatus @default(PENDING)
  createdAt       DateTime         @default(now())
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  photo           Photo            @relation(fields: [photoId], references: [id], onDelete: Cascade)
  athlete         User             @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([photoId, athleteId])
  @@index([organizationId, athleteId, status])
  @@index([organizationId, photoId])
  @@map("photo_athlete_matches")
  @@schema("public")
}

model PhotoPurchase {
  id             String              @id @default(cuid())
  organizationId String
  athleteId      String
  paymentId      String?
  totalCents     Int                 @default(0)
  totalPoints    Int                 @default(0)
  status         PhotoPurchaseStatus @default(PENDING)
  metadata       Json?
  createdAt      DateTime            @default(now())
  paidAt         DateTime?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete        User                @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  items          PhotoPurchaseItem[]

  @@index([organizationId, athleteId, createdAt(sort: Desc)])
  @@index([organizationId, status, createdAt(sort: Desc)])
  @@map("photo_purchases")
  @@schema("public")
}

model PhotoPurchaseItem {
  id         String        @id @default(cuid())
  purchaseId String
  photoId    String
  priceCents Int           @default(0)
  pointsCost Int           @default(0)
  createdAt  DateTime      @default(now())
  purchase   PhotoPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  photo      Photo         @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([purchaseId, photoId])
  @@index([photoId])
  @@map("photo_purchase_items")
  @@schema("public")
}

model PhotoUnlock {
  id                 String          @id @default(cuid())
  organizationId     String
  athleteId          String
  photoId            String
  unlockType         PhotoUnlockType
  paymentId          String?
  pointTransactionId String?
  expiresAt          DateTime?
  createdAt          DateTime        @default(now())
  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete            User            @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  photo              Photo           @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([organizationId, athleteId, photoId])
  @@index([organizationId, athleteId, createdAt(sort: Desc)])
  @@index([organizationId, photoId])
  @@map("photo_unlocks")
  @@schema("public")
}

model Sponsor {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  logoUrl        String?
  description    String?
  websiteUrl     String?
  sponsorType    String             @default("BRAND")
  status         SponsorStatus      @default(ACTIVE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       SponsorContact[]
  campaigns      SponsorCampaign[]
  placements     SponsorPlacement[]
  metrics        SponsorMetric[]

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@map("sponsors")
  @@schema("public")
}

model SponsorContact {
  id             String       @id @default(cuid())
  organizationId String
  sponsorId      String
  name           String
  email          String?
  phone          String?
  roleTitle      String?
  createdBy      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sponsor        Sponsor      @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  creator        User?        @relation("SponsorContactCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([organizationId, sponsorId])
  @@map("sponsor_contacts")
  @@schema("public")
}

model SponsorCampaign {
  id             String                 @id @default(cuid())
  organizationId String
  sponsorId      String
  title          String
  description    String?
  campaignType   String
  budgetCents    Int                    @default(0)
  pointsBudget   Int                    @default(0)
  startsAt       DateTime?
  endsAt         DateTime?
  status         SponsorCampaignStatus  @default(DRAFT)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sponsor        Sponsor                @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  placements     SponsorPlacement[]
  events         SponsorCampaignEvent[]

  @@index([organizationId, sponsorId, status])
  @@index([organizationId, status, startsAt, endsAt])
  @@map("sponsor_campaigns")
  @@schema("public")
}

model SponsorPlacement {
  id             String                @id @default(cuid())
  organizationId String
  sponsorId      String
  campaignId     String?
  placementArea  String
  priority       Int                   @default(0)
  startsAt       DateTime?
  endsAt         DateTime?
  status         SponsorCampaignStatus @default(ACTIVE)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sponsor        Sponsor               @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  campaign       SponsorCampaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([organizationId, placementArea, status, priority])
  @@index([organizationId, sponsorId])
  @@map("sponsor_placements")
  @@schema("public")
}

model SponsorCampaignEvent {
  id         String          @id @default(cuid())
  campaignId String
  eventId    String
  createdAt  DateTime        @default(now())
  campaign   SponsorCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  event      Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([campaignId, eventId])
  @@index([eventId])
  @@map("sponsor_campaign_events")
  @@schema("public")
}

model SponsorMetric {
  id             String       @id @default(cuid())
  organizationId String
  sponsorId      String
  campaignId     String?
  placementArea  String?
  metricName     String
  metricValue    Int          @default(0)
  periodStart    DateTime
  periodEnd      DateTime
  metadata       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sponsor        Sponsor      @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@index([organizationId, sponsorId, metricName, periodEnd(sort: Desc)])
  @@map("sponsor_metrics")
  @@schema("public")
}
