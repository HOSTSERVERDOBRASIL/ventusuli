# =========================
# Required (all environments)
# =========================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres@db:5432/ventu_suli?schema=public
JWT_SECRET=replace-with-64-char-random-secret
NEXTAUTH_SECRET=replace-with-32-char-random-secret

# =========================
# Runtime mode
# =========================
NEXT_PUBLIC_DEMO_MODE=false
DEMO_SEED_ENABLED=false
PUBLIC_ADMIN_REGISTRATION_ENABLED=true
NEXT_PUBLIC_PUBLIC_ADMIN_REGISTRATION_ENABLED=true
SUPER_ADMIN_EMAIL=superadmin@ventu.demo
SUPER_ADMIN_PASSWORD=SuperAdmin@1234

# Demo auth fallback (disable for environment parity)
# Quando true, habilita login demo APENAS fora de production.
DEMO_AUTH_ENABLED=false
DEMO_EMAIL=admin@ventu.demo
DEMO_PASSWORD=Demo@1234
DEMO_ATHLETE_EMAIL=atleta@ventu.demo
DEMO_ATHLETE_PASSWORD=Atleta@1234

# =========================
# Optional integrations
# =========================
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_SANDBOX=true
EFI_CERT_PATH=./certs/efi.p12
PAYMENT_WEBHOOK_SECRET=

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Optional override. Default: ${NEXT_PUBLIC_APP_URL}/api/integrations/strava/callback
STRAVA_REDIRECT_URI=
# Required for GET verification at /api/integrations/strava/webhook
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Notices/Telegram:
# - TELEGRAM_NOTICES_ENABLED habilita envio global default
# - TELEGRAM_CHAT_ID e TELEGRAM_BOT_TOKEN podem ser sobrescritos por organization.settings.integrations.telegram
TELEGRAM_NOTICES_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

RATE_LIMIT_BACKEND=auto
REDIS_URL=
# Production rate limit backend (choose one):
# 1) Railway Redis: REDIS_URL=redis://...
# 2) Upstash Redis REST:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=
STORAGE_DRIVER=local
UPLOAD_MAX_FILE_MB=5
